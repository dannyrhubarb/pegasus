# Level — The Hollows: the first hand-drawn world (Across / Elasto Mania
# style). No procedural generator: every `poly` line below is a solid rock
# mass drawn by hand, and the playable space is what's left open — five
# chambers joined by tunnels, each chamber holding a landing pad to visit
# (+100 on the first touch-down; collectibles may replace pads here later).
#
# Map (side view, y up):                 ┌────────────────────────┐
#   upper chamber (x -20..20, y 32..50) ─┤ tunnel ├─ attic (30..58)
#          │ central passage (x -4..4)              │ east passage (x 40..48)
#   west chamber ─ tunnel ─ spawn chamber ─ tunnel ─ east chamber   (y ~0..14)
#
# Rock polygons may overlap (buried edges are unreachable); the outer frame
# is four fat slabs. Tunnels are kept ≥ 6.5 m tall — the ship is ~1.5 m.
name = The Hollows
scoring = pads
shafts = off
obstacles = off
spawn_y = -0.5

# Landing pads: spawn, west, east, upper, attic.
pad = 0,-0.5
pad = -45,-0.4
pad = 45,0.6
pad = 12,32.9
pad = 53,36.6

# Frame: bottom slab (its top edge is the lower chambers' floor), left/right
# slabs, top slab (its bottom edge is the upper rooms' ceiling).
poly = -72,-9 72,-9 72,4 59,2 57,0.2 50,-0.3 46,0.1 44,0.1 40,-0.4 34,0.3 30.5,0.8 28,2.2 16,2.4 13.5,0.2 9,-0.8 4,-1.2 -3,-1.1 -8,-0.7 -13,-1.3 -15.5,1.2 -28,1.4 -30.5,-0.6 -36,-1.2 -43,-0.7 -47,-0.9 -52,-0.4 -57,-1.1 -72,3
poly = -72,-9 -58.5,-9 -57.6,-3 -58.8,3 -57.4,8 -58.6,13 -57.8,20 -58.7,27 -57.5,33 -58.5,40 -57.7,46 -58.4,52 -58,59 -72,59
poly = 58.2,-9 72,-9 72,59 58,59 57.6,52 58.6,46 57.8,40 58.5,33 57.7,26 58.6,20 57.9,14 58.7,8 57.8,2 58.2,-3
poly = -72,49 -60,50.5 -50,49.4 -40,50.6 -30,49.6 -21,50.4 -13,49.3 -5,50.5 3,49.5 11,50.6 19,49.6 27,50.3 35,49.4 43,50.5 51,49.5 59,50.4 72,49.5 72,59 -72,59

