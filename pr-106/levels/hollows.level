# tops are the upper chamber / attic floors.
poly = -60,13.9 -53,14.5 -47,13.6 -41,14.3 -35,13.7 -31.2,14.1 -29.9,9.7 -24,9.1 -19,9.8 -15.3,9.2 -14.1,12.7 -9,13.3 -5.5,12.6 -4.1,13.1 -4.6,17 -3.8,22 -4.7,27 -4.2,31.9 -9,32.5 -15,31.8 -20.5,32.4 -30,31.9 -40,32.4 -50,31.8 -60,32.2
