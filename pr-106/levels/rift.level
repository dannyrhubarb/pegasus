# Level — The Rift: a brand-new infinite procedural cave. A non-zero seed
# re-phases every cave harmonic and re-keys every slot hash, so the whole
# world — curves, pinches, boulders, pads and shaft positions — is different
# from the legacy cave. Everything is on: vertical shafts to climb, boulders
# to dodge, refueling pads a little farther apart than usual.
name = The Rift
scoring = distance
shafts = on
obstacles = on
pad_spacing = 150
seed = 20260717
